/* bezier_trajectory.c - Cubic Bezier foot trajectory */
#include <math.h>
#include <stddef.h>

#define DEG_TO_RAD 0.01745329252f

typedef struct {
    float x;
    float y;
    float z;
} Vec3;

static Vec3 CubicBezier(Vec3 p0, Vec3 p1, Vec3 p2, Vec3 p3, float t)
{
    float u = 1.0f - t;

    Vec3 p = {
        u*u*u*p0.x + 3*u*u*t*p1.x + 3*u*t*t*p2.x + t*t*t*p3.x,
        u*u*u*p0.y + 3*u*u*t*p1.y + 3*u*t*t*p2.y + t*t*t*p3.y,
        u*u*u*p0.z + 3*u*u*t*p1.z + 3*u*t*t*p2.z + t*t*t*p3.z
    };
    return p;
}

void Bezier_GenerateSwing(Vec3 target, float stride,
                          float lift_height, float heading_deg,
                          Vec3 *trajectory, size_t count)
{
    float heading = heading_deg * DEG_TO_RAD;
    Vec3 direction = {cosf(heading), sinf(heading), 0.0f};

    Vec3 p3 = target;
    Vec3 p0 = {
        target.x - stride * direction.x,
        target.y - stride * direction.y,
        target.z
    };

    float control_lift = 4.0f * lift_height / 3.0f;

    Vec3 p1 = {
        p0.x + stride * direction.x / 3.0f,
        p0.y + stride * direction.y / 3.0f,
        p0.z + control_lift
    };

    Vec3 p2 = {
        p0.x + 2.0f * stride * direction.x / 3.0f,
        p0.y + 2.0f * stride * direction.y / 3.0f,
        p0.z + control_lift
    };

    for (size_t i = 0; i < count; ++i) {
        float t = (count > 1) ? (float)i / (float)(count - 1) : 0.0f;
        trajectory[i] = CubicBezier(p0, p1, p2, p3, t);
    }
}
